---
import Icon from "@/components/Icon.astro";
import { SOCIALS } from "@/data/site";

interface Props {
  centered?: boolean;
  compact?: boolean;
}

const { centered = false, compact = false } = Astro.props;
---

<ul class:list={["socials", { "socials--centered": centered, "socials--compact": compact }]}>
  {SOCIALS.map((social) => (
    <li>
      <a
        href={social.href}
        aria-label={social.label}
        title={social.label}
        target={social.href.startsWith("http") ? "_blank" : undefined}
        rel={social.href.startsWith("http") ? "noreferrer" : undefined}
      >
        <Icon name={social.icon} class="ui-icon socials__icon" />
        <span class="sr-only">{social.label}</span>
      </a>
    </li>
  ))}
</ul>
