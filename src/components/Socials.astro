---
import Icon from "@/components/Icon.astro";
import { SOCIALS } from "@/data/site";

const { centered = false } = Astro.props;

const iconNameByLabel = {
  GitHub: "github",
  LinkedIn: "linkedin",
  X: "x",
  Email: "email"
} as const;
---

<ul class:list={["socials", { "socials--centered": centered }]}>
  {SOCIALS.map((social) => (
    <li>
      <a
        href={social.href}
        aria-label={social.label}
        title={social.label}
        target={social.href.startsWith("http") ? "_blank" : undefined}
        rel={social.href.startsWith("http") ? "noreferrer" : undefined}
      >
        <Icon
          name={iconNameByLabel[social.label as keyof typeof iconNameByLabel]}
          class="ui-icon socials__icon"
        />
      </a>
    </li>
  ))}
</ul>
