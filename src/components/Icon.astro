---
interface Props {
  name:
    | "github"
    | "linkedin"
    | "x"
    | "email"
    | "search"
    | "rss"
    | "calendar"
    | "sun"
    | "moon"
    | "arrow-right";
  class?: string;
}

const { name, class: className } = Astro.props;
---

{
  name === "github" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 19c-4.3 1.4-4.3-2.5-6-3" />
      <path d="M15 21v-3.5c0-1 .1-1.4-.5-2c2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2a4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6c-.6.6-.6 1.2-.5 2V21" />
    </svg>
  )
}
{
  name === "linkedin" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 11v5" />
      <path d="M8 8v.01" />
      <path d="M12 16v-5" />
      <path d="M16 16v-3a2 2 0 1 0-4 0" />
      <path d="M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z" />
    </svg>
  )
}
{
  name === "x" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4l11.733 16H20L8.267 4z" />
      <path d="M4 20l6.768-6.768" />
      <path d="M13.228 10.772L20 4" />
    </svg>
  )
}
{
  name === "email" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
      <path d="M3 7l9 6l9-6" />
    </svg>
  )
}
{
  name === "search" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0" />
      <path d="M21 21l-6-6" />
    </svg>
  )
}
{
  name === "rss" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4a16 16 0 0 1 16 16" />
      <path d="M4 11a9 9 0 0 1 9 9" />
      <path d="M5 19a1 1 0 1 0 0-.01" />
    </svg>
  )
}
{
  name === "calendar" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" />
      <path d="M16 3v4" />
      <path d="M8 3v4" />
      <path d="M4 11h16" />
    </svg>
  )
}
{
  name === "sun" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
      <path d="M3 12h1" />
      <path d="M20 12h1" />
      <path d="M12 3v1" />
      <path d="M12 20v1" />
      <path d="M5.6 5.6l.7.7" />
      <path d="M17.7 17.7l.7.7" />
      <path d="M18.4 5.6l-.7.7" />
      <path d="M6.3 17.7l-.7.7" />
    </svg>
  )
}
{
  name === "moon" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446A9 9 0 1 1 12 3z" />
    </svg>
  )
}
{
  name === "arrow-right" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14" />
      <path d="M13 18l6-6" />
      <path d="M13 6l6 6" />
    </svg>
  )
}
