---
import SiteLayout from "@/layouts/SiteLayout.astro";
import Hr from "@/components/Hr.astro";
import Socials from "@/components/Socials.astro";
import { NOW_PAGE, SITE, WRITING } from "@/data/site";

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric"
});
---

<SiteLayout title="Jaunius Kadunas" description={NOW_PAGE.description}>
  <main id="main-content" data-layout="home" class="page-shell">
    <section class="hero hero--home">
      <img
        src={SITE.avatar}
        alt="Jaunius Kadunas"
        class="avatar-image"
        width="152"
        height="152"
      />
      <div class="hero-copy">
        <p class="eyebrow">{NOW_PAGE.eyebrow}</p>
        <div class="hero-heading">
          <h1>{NOW_PAGE.heroTitle}</h1>
          <a href={WRITING.feed} class="hero-rss" target="_blank" rel="noreferrer">
            RSS
          </a>
        </div>
        <p class="hero-role">{NOW_PAGE.role}</p>
        <p>{NOW_PAGE.heroBody}</p>
        <p class="hero-writing">
          I publish longer notes on <a href={WRITING.home} target="_blank" rel="noreferrer">{WRITING.title}</a>.
          {` `}
          {WRITING.intro}
        </p>
        <div class="hero-meta">
          <span>{NOW_PAGE.location}</span>
          <span>Updated {NOW_PAGE.updated}</span>
        </div>
        <Socials />
        <ul class="link-list">
          {NOW_PAGE.quickLinks.map((link) => (
            <li>
              <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <Hr />

    <section class="content-section content-section--tight">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Writing</p>
          <h2>Latest Posts</h2>
        </div>
        <a href={WRITING.archive} class="section-link" target="_blank" rel="noreferrer">
          All Posts
        </a>
      </div>

      <div class="post-list">
        {WRITING.posts.map((post) => (
          <article class="post-card">
            <p class="post-meta">
              <time datetime={post.publishedAt}>
                {dateFormatter.format(new Date(`${post.publishedAt}T00:00:00Z`))}
              </time>
              <span>Substack</span>
            </p>
            <h3>
              <a href={post.href} target="_blank" rel="noreferrer">
                {post.title}
              </a>
            </h3>
            <p>{post.excerpt}</p>
          </article>
        ))}
      </div>
    </section>

    {NOW_PAGE.sections.map((section) => (
      <section class="content-section content-section--summary">
        <div class="section-heading">
          <div>
            <p class="section-kicker">{section.title}</p>
            <h2>What I’m Focused On</h2>
          </div>
          <a href="/about/" class="section-link">More About Me</a>
        </div>
        {section.body.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
        {section.bullets && (
          <ul class="section-list">
            {section.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
      </section>
    ))}
  </main>
</SiteLayout>
