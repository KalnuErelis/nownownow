---
import SiteLayout from "@/layouts/SiteLayout.astro";
import Hr from "@/components/Hr.astro";
import Icon from "@/components/Icon.astro";
import Socials from "@/components/Socials.astro";
import { NOW_PAGE, SITE, WRITING } from "@/data/site";

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric"
});
---

<SiteLayout title="Jaunius Kadunas" description={NOW_PAGE.description}>
  <main id="main-content" data-layout="home" class="page-shell">
    <section class="hero hero--home">
      <a href="/about/" class="hero-avatar-link" aria-label="About Jaunius Kadunas">
        <img
          src={SITE.avatar}
          alt="Jaunius Kadunas"
          class="avatar-image"
          width="160"
          height="160"
        />
      </a>
      <div class="hero-copy">
        <div class="hero-heading">
          <div>
            <p class="eyebrow">{NOW_PAGE.eyebrow}</p>
            <h1>{NOW_PAGE.heroTitle}</h1>
          </div>
          <a href={WRITING.feed} class="hero-rss" target="_blank" rel="noreferrer" aria-label="RSS feed" title="RSS feed">
            <Icon name="rss" class="ui-icon hero-rss__icon" />
          </a>
        </div>
        <p class="hero-role">{NOW_PAGE.role}</p>
        <p class="hero-copy__lede">{NOW_PAGE.heroBody}</p>
        <p class="hero-copy__support">{NOW_PAGE.heroSupport}</p>
        <Socials />
        <ul class="hero-links">
          {NOW_PAGE.quickLinks.map((link) => (
            <li>
              <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="hero-meta">
          <span>{SITE.location}</span>
          <span>Updated {SITE.updated}</span>
        </div>
      </div>
    </section>

    <Hr />

    <section class="content-section content-section--tight">
      <div class="section-heading">
        <div>
          <h2>Latest Posts</h2>
        </div>
        <a href={WRITING.archive} class="section-link" target="_blank" rel="noreferrer">
          All Posts
        </a>
      </div>

      <div class="post-list">
        {WRITING.posts.map((post) => (
          <article class="post-card">
            <h3>
              <a href={post.href} target="_blank" rel="noreferrer">
                {post.title}
              </a>
            </h3>
            <p class="post-meta">
              <span class="post-meta__item">
                <Icon name="calendar" class="ui-icon post-meta__icon" />
                <time datetime={post.publishedAt}>
                  {dateFormatter.format(new Date(`${post.publishedAt}T00:00:00Z`))}
                </time>
              </span>
              <span>{post.source}</span>
              <span>{post.readingTime}</span>
            </p>
            <p>{post.excerpt}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section content-section--summary">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Now</p>
          <h2>{NOW_PAGE.nowTitle}</h2>
        </div>
        <a href="/about/" class="section-link">More About Me</a>
      </div>
      {NOW_PAGE.nowBody.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <ul class="section-list">
        {NOW_PAGE.bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>
  </main>
</SiteLayout>
