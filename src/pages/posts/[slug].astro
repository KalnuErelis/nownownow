---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { importedArticles } from "@/data/articles";

export function getStaticPaths() {
  return importedArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
---

<SiteLayout title={`${article.title} | Jaunius Kadunas`} description={article.description}>
  <main id="main-content" class="page-shell">
    <article class="article-page">
      <p class="eyebrow">Post</p>
      <h1>{article.title}</h1>
      <p class="post-meta article-meta">
        <time datetime={article.publishedAt}>
          {dateFormatter.format(new Date(`${article.publishedAt}T00:00:00Z`))}
        </time>
        <span>{article.readingTime}</span>
      </p>
      {article.subtitle && <p class="article-subtitle">{article.subtitle}</p>}

      <div class="article-content" set:html={article.bodyHtml} />
    </article>
  </main>
</SiteLayout>
