---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { ABOUT_PAGE, SITE, WRITING } from "@/data/site";

const imageAlt = "Jaunius Kadunas";
---

<SiteLayout title="About | Jaunius Kadunas" description={ABOUT_PAGE.description}>
  <main id="main-content" class="page-shell page-shell--about">
    <section class="about-page">
      <h1>About</h1>

      <div class="about-intro">
        <div class="about-intro__media">
          <img src={SITE.avatar} alt={imageAlt} class="about-image" width="320" height="320" />
        </div>
        <div class="about-intro__copy">
          {ABOUT_PAGE.intro.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <ul class="link-list">
            {ABOUT_PAGE.summaryLinks.map((link) => (
              <li>
                <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <section class="about-section">
        <h2>Quick Context</h2>
        <ul class="section-list">
          {ABOUT_PAGE.current.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      {ABOUT_PAGE.sections.map((section) => (
        <section class="about-section">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <ul class="section-list">
            {section.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}

      <section class="about-section">
        <h2>{ABOUT_PAGE.activity.title}</h2>
        <p>{ABOUT_PAGE.activity.body}</p>
        <ul class="link-list link-list--stacked">
          {ABOUT_PAGE.activity.links.map((link) => (
            <li>
              <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="subscribe-card">
        <h2>{ABOUT_PAGE.subscribe.title}</h2>
        <p>{ABOUT_PAGE.subscribe.body}</p>
        <a href={ABOUT_PAGE.subscribe.ctaHref} class="subscribe-card__cta" target="_blank" rel="noreferrer">
          {ABOUT_PAGE.subscribe.ctaLabel}
        </a>
        <p class="subscribe-card__aside">{ABOUT_PAGE.subscribe.aside}</p>
      </section>

      <section class="about-section about-section--note">
        <p>{ABOUT_PAGE.note}</p>
        <p>
          Writing lives on <a href={WRITING.home} target="_blank" rel="noreferrer">{WRITING.title}</a>. The fastest way to reach me is still <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </section>
    </section>
  </main>
</SiteLayout>
