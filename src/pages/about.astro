---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { ABOUT_PAGE, SITE } from "@/data/site";

const [introLede, ...introSupport] = ABOUT_PAGE.intro;
---

<SiteLayout title={`${ABOUT_PAGE.title} | Jaunius Kadunas`} description={ABOUT_PAGE.description}>
  <main id="main-content" class="page-shell page-shell--about">
    <section class="about-page">
      <h1>{ABOUT_PAGE.heading}</h1>

      <div class="about-intro">
        <div class="about-intro__media">
          <img
            src={ABOUT_PAGE.image}
            alt={ABOUT_PAGE.imageAlt}
            class="about-image"
            width="320"
            height="320"
          />
          <ul class="link-list about-intro__summary-links">
            {ABOUT_PAGE.summaryLinks.map((link) => (
              <li>
                <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="about-intro__copy">
          <div class="about-intro__lede">
            <p>{introLede}</p>
          </div>
          <div class="about-intro__support">
            {introSupport.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>

      <section class="about-section">
        <p class="section-kicker">{ABOUT_PAGE.labels.snapshot}</p>
        <h2>{ABOUT_PAGE.labels.quickContext}</h2>
        <div class="about-facts">
          {ABOUT_PAGE.current.map((item) => (
            <div class="about-facts__item">
              <p>{item}</p>
            </div>
          ))}
        </div>
      </section>

      {ABOUT_PAGE.sections.map((section) => (
        <section class="about-section about-section--story">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <ul class="about-section__list">
            {section.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}

      <section class="about-section">
        <p class="section-kicker">{ABOUT_PAGE.labels.currentSignal}</p>
        <h2>{ABOUT_PAGE.activity.title}</h2>
        <p>{ABOUT_PAGE.activity.body}</p>
        <div class="activity-card">
          <img
            src={ABOUT_PAGE.activity.chartUrl}
            alt={ABOUT_PAGE.activity.chartAlt}
            class="activity-card__image"
            loading="lazy"
          />
          <div class="activity-card__footer">
            <ul class="link-list link-list--stacked activity-card__links">
              {ABOUT_PAGE.activity.links.map((link) => (
                <li>
                  <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="subscribe-card">
        <div class="subscribe-card__copy">
          <p class="section-kicker">{ABOUT_PAGE.labels.subscribe}</p>
          <h2>{ABOUT_PAGE.subscribe.title}</h2>
          <p>{ABOUT_PAGE.subscribe.body}</p>
        </div>
        <div class="subscribe-card__form-wrap">
          <form
            action={ABOUT_PAGE.subscribe.action}
            method="post"
            target="_blank"
            class="subscribe-form"
          >
            <input type="hidden" name="tag" value={ABOUT_PAGE.subscribe.tag} />
            <div class="subscribe-form__field">
              <label for="subscribe-name" class="subscribe-form__label">Name</label>
              <input
                id="subscribe-name"
                type="text"
                name="name"
                placeholder={ABOUT_PAGE.subscribe.namePlaceholder}
                class="subscribe-form__input"
              />
            </div>
            <div class="subscribe-form__field">
              <label for="subscribe-email" class="subscribe-form__label">Email</label>
              <input
                id="subscribe-email"
                type="email"
                name="email"
                placeholder={ABOUT_PAGE.subscribe.emailPlaceholder}
                class="subscribe-form__input"
                required
              />
            </div>
            <button type="submit" class="subscribe-card__cta">
              {ABOUT_PAGE.subscribe.buttonLabel}
            </button>
          </form>
          <p class="subscribe-card__aside">{ABOUT_PAGE.subscribe.aside}</p>
        </div>
      </section>

      <section class="about-section about-section--note">
        <p class="section-kicker">{ABOUT_PAGE.labels.notes}</p>
        <p>{ABOUT_PAGE.note}</p>
        <p>
          {ABOUT_PAGE.archiveNote.prefix} <a href="/search/">{ABOUT_PAGE.archiveNote.archiveLabel}</a>. {ABOUT_PAGE.archiveNote.middle} <a href={`mailto:${SITE.email}`}>{ABOUT_PAGE.archiveNote.emailLabel}</a>.
        </p>
        <div class="about-note__meta">
          <p class="about-utility-note">{ABOUT_PAGE.utilityNote}</p>
          <p class="about-imprint">{ABOUT_PAGE.imprint}</p>
        </div>
      </section>
    </section>
  </main>
</SiteLayout>
